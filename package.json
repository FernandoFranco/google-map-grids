{
  "name": "google-map-grids",
  "version": "0.1.0",
  "description": "React component library — Google Map Grids",
  "license": "MIT",
  "author": "Fernando Franco <atr.franco@gmail.com> (https://github.com/FernandoFranco)",
  "homepage": "https://fernandofranco.github.io/google-map-grids/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FernandoFranco/google-map-grids.git"
  },
  "bugs": {
    "url": "https://github.com/FernandoFranco/google-map-grids/issues"
  },
  "keywords": [
    "react",
    "google-maps",
    "maps",
    "grid",
    "mgrs",
    "utm",
    "component-library",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "packageManager": "yarn@4.17.0",
  "files": [
    "dist"
  ],
  "main": "./dist/google-map-grids.cjs",
  "module": "./dist/google-map-grids.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/google-map-grids.js",
      "require": "./dist/google-map-grids.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build",
    "build:storybook": "storybook build",
    "dev": "storybook dev -p 3000",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "yarn build",
    "storybook": "storybook dev -p 3000",
    "test": "vitest"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/browser": "3.2.6",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^16.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.4.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^3.2.4"
  },
  "resolutions": {
    "brace-expansion@^1.1.7": "1.1.16",
    "js-yaml@^4.1.1": "4.3.0"
  }
}
