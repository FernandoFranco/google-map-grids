{
  "name": "google-map-grids",
  "version": "0.1.0",
  "description": "React component library — Google Map Grids",
  "type": "module",
  "packageManager": "yarn@4.17.0",
  "files": [
    "dist"
  ],
  "main": "./dist/google-map-grids.cjs",
  "module": "./dist/google-map-grids.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/google-map-grids.js",
      "require": "./dist/google-map-grids.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "preview": "vite preview",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
