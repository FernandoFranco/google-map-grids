{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Storybook",
      "type": "shell",
      "command": "yarn dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Storybook",
          "endsPattern": "Storybook .* started"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}
